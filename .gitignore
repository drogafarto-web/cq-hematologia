# Build output — Netlify gera o seu próprio
dist/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
firebase-debug.log*
firebase-debug.*.log*

# Firebase cache
.firebase/

# Firebase config

# Uncomment this if you'd like others to create their own Firebase project.
# For a team working on the same Firebase project(s), it is recommended to leave
# it commented so all members can deploy to the same project(s) in .firebaserc.
# .firebaserc

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc test coverage
.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file — todos com `.env` no início.
# Inclui .env.test e .env.local pra impedir commit acidental de senhas
# de smoke test ou credenciais locais.
.env
.env.local
.env.*.local
.env.test
**/.env.test
**/.env.local

# dataconnect generated files
.dataconnect

# Local Netlify folder
.netlify

# Backups
backup_*/

# Credenciais e service accounts — NUNCA commitar
# Padrão amplo: pega `service-account.json`, `service-account.json.json`
# (typo já visto), `service-account-prod.json`, etc.
service-account*.json
**/service-account*.json
*.pem
*.p12

# Defense-in-depth pós-incidente 2026-05-08 (NOTIVISA plaintext leak):
# qualquer arquivo cuja namesake sugira credenciais é bloqueado por padrão.
# Stubs explicitamente versionados (sem segredos) são reintroduzidos
# pela exceção mais abaixo.
**/*CREDENTIALS*.md
**/*CREDENCIAIS*.md
**/*PASSWORD*.md
**/*SECRET*.md
**/*credentials*.json
**/*secrets*.json
# Exceção: stubs de documentação que apontam para Secret Manager.
# Esses arquivos NÃO podem conter segredos; revisar no PR.
!docs/NOTIVISA_CREDENCIAIS_AUDIT.md
!src/features/notivisa-portal/NOTIVISA_CREDENTIALS.md
!docs/NOTIVISA_CREDENTIAL_ROTATION_PROCEDURES.md

# Ops scripts ad-hoc na raiz de functions/ — usam Admin SDK + service account
# pra rodar uma vez. Não vão pro repo. Scripts versionados ficam em
# functions/scripts/ (allowlisted abaixo).
functions/run*.js
functions/apply-claims*.js
run-provision*.mjs

# Anexos WhatsApp do trabalho de campo (referência local, não código)
modulo educa*/*.jpeg
modulo educa*/*.jpg
modulo educa*/*.png
modulo educa*/*.ogg
modulo educa*/*.mp3
modulo educa*/*.mp4

# Arquivos de planos e scripts locais — bloqueia por padrão
plans/
scripts/*
# Exceção: scripts/migrations/ hospeda migrations versionadas (PR1+)
# Negação precisa do glob direto, sem o trailing slash, pra git reconhecer
!scripts/migrations
!scripts/migrations/**
# Exceção: scripts/staging/ hospeda scripts de automação de staging versionados
!scripts/run-staging-tests.sh
!scripts/seed-staging-data.mjs
!scripts/watch-staging-setup.mjs
# Exceção: deploy gate (ADR-0018) — bloqueia deploy de functions com secrets PENDING_SET_*
!scripts/preflight-secrets-check.sh
!scripts/perf-validate.mjs
# Exceção: functions/scripts/ hospeda utilitários de dev versionados
!functions/scripts/
!functions/scripts/**

# Arquivos markdown temporários (exceto README e CLAUDE)
THEME_UPDATE.md
"popular produção.md"

# TypeScript build output — regenerated from functions/src/
functions/lib/

# Outputs de smoke tests dos geradores de PDF (dev-only)
functions/smoke-*.pdf
functions/tmp/

# Smoke test outputs — screenshots, logs, audits gerados por execução.
# Os specs/configs em si são versionados; só os artefatos de execução não.
smoke-test/playwright-report/
smoke-test/test-results/
smoke-test/fail*.png
smoke-test/gemini-audit-*/
smoke-test-openclaw/smoke-ciq-imuno-*/

# Detox / Jest E2E test result artifacts
test-results.xml
test-results/

# Anexos work-in-progress do módulo educação continuada
modulo educa*/*.pdf
modulo educa*/*.xlsx
modulo educa*/*.docx
.claude/worktrees/
