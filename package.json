{
  "name": "hc-quality",
  "version": "1.4.1",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "vitest run test/smoke",
    "test:smoke:watch": "vitest test/smoke",
    "test:smoke:ci": "vitest run test/smoke --coverage --reporter=junit --outputFile=test-results.xml",
    "test:smoke:staging": "FIREBASE_EMULATOR_HOST=localhost:9999 vitest run test/smoke",
    "staging:seed": "node scripts/seed-staging-data.mjs",
    "staging:watch": "node scripts/watch-staging-setup.mjs",
    "fb": "firebase",
    "fb:deploy": "firebase deploy --project hmatologia2",
    "fb:logs:backup": "firebase functions:log --only scheduledDailyBackup --project hmatologia2",
    "fb:logs:ec": "firebase functions:log --only ec_scheduledAlertasVencimento --project hmatologia2",
    "analyze": "cross-env ANALYZE=true npm run build && start dist/stats.html",
    "perf:validate": "node scripts/perf-validate.mjs"
  },
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@sentry/react": "10.50.0",
    "@sentry/vite-plugin": "5.2.1",
    "@tailwindcss/vite": "^4.2.2",
    "dompurify": "3.4.2",
    "firebase": "^10.14.1",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^5.6.205",
    "protobufjs": "7.5.6",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-to-print": "^3.3.0",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "cross-env": "10.1.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-admin": "^13.8.0",
    "firebase-tools": "13.35.1",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "marked": "18.0.3",
    "prettier": "^3.8.3",
    "puppeteer": "24.43.0",
    "rollup-plugin-visualizer": "7.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.4"
  }
}
