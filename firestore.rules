rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      // Fast path: custom claim set by Cloud Function (no Firestore read)
      return request.auth.token.isSuperAdmin == true ||
        // Fallback: Firestore check for users created before claim migration
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true);
    }

    function isActiveMemberOfLab(labId) {
      let memberPath = /databases/$(database)/documents/labs/$(labId)/members/$(request.auth.uid);
      return exists(memberPath) && get(memberPath).data.active == true;
    }

    function getMemberRole(labId) {
      return get(/databases/$(database)/documents/labs/$(labId)/members/$(request.auth.uid)).data.role;
    }

    function isAdminOrOwner(labId) {
      let role = getMemberRole(labId);
      return role == 'admin' || role == 'owner';
    }

    // ── Module access (custom claims) ─────────────────────────────────────────
    //
    // Custom claims are set server-side by the setModulesClaims Cloud Function.
    // Using claims here avoids an extra Firestore read per rule evaluation and
    // works offline (the claim is embedded in the signed JWT).
    //
    // Safe migration pattern:
    //   - If a user has NO modules claim yet (legacy / pre-migration), the
    //     `request.auth.token.get('modules', {})` returns {} and the check
    //     returns false — access is DENIED for that module path.
    //   - Run setModulesClaims for all existing users before enabling the gate
    //     on a collection, or use `|| !('modules' in request.auth.token)` as a
    //     temporary bypass during the rollout window.
    //
    // Usage:  hasModuleAccess('hematologia')
    //         hasModuleAccess('bioquimica')
    function hasModuleAccess(module) {
      return request.auth.token.get('modules', {})[module] == true;
    }

    // ── /users ────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isSuperAdmin();
      allow create: if isSuperAdmin() || request.auth.uid == userId;
      // Self-updates restricted to safe fields; SuperAdmin can update anything
      allow update: if isSuperAdmin() ||
        (request.auth.uid == userId &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['contact', 'displayName', 'photoURL', 'activeLabId', 'pendingLabId']));
      allow delete: if isSuperAdmin();
    }

    // ── /labs ─────────────────────────────────────────────────────────────────

    match /labs/{labId} {
      allow get: if isSuperAdmin() || isActiveMemberOfLab(labId);
      allow list: if isAuthenticated(); // Allow users to list labs to request access
      allow create, delete: if isSuperAdmin();
      // Admin/owner can update their own lab profile (name, contact, address, etc.)
      // but only superAdmin can create or delete labs.
      allow update: if isSuperAdmin() || isAdminOrOwner(labId);

      // /labs/{labId}/members
      match /members/{uid} {
        allow get: if isSuperAdmin() || request.auth.uid == uid || isAdminOrOwner(labId);
        allow list: if isSuperAdmin() || isAdminOrOwner(labId);
        allow write: if isSuperAdmin() || isAdminOrOwner(labId);
      }

      // /labs/{labId}/data
      match /data/{dataPath} {
        allow read: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow create, delete: if isSuperAdmin() || isAdminOrOwner(labId);
        allow update: if (isSuperAdmin() || isActiveMemberOfLab(labId)) &&
                       (isAdminOrOwner(labId) || dataPath == 'appState');
      }

      // /labs/{labId}/lots
      //
      // Module gate: members can only read lots if they hold the matching module
      // claim in their JWT. Write (create/update/delete) is kept admin-only and
      // does not require the module claim — admins manage all lab data.
      //
      // ROLLOUT NOTE: replace `|| !('modules' in request.auth.token)` with
      // `|| false` once setModulesClaims has been run for every existing user.
      match /lots/{lotId} {
        allow read: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) &&
            (hasModuleAccess('hematologia') || !('modules' in request.auth.token)));
        allow write: if isSuperAdmin() || (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));

        // /labs/{labId}/lots/{lotId}/runs
        match /runs/{runId} {
          allow read: if isSuperAdmin() ||
            (isActiveMemberOfLab(labId) &&
              (hasModuleAccess('hematologia') || !('modules' in request.auth.token)));
          allow create, update: if isSuperAdmin() || isActiveMemberOfLab(labId);
          allow delete: if isSuperAdmin() || (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));
        }
      }

      // /labs/{labId}/ciq-imuno — Módulo Imunologia (CIQ categórico R/NR)
      // Claim JWT: 'imunologia' (setModulesClaims com { imunologia: true })
      // ROLLOUT: sem bypass de migração — claim obrigatória desde o primeiro deploy.
      // Rodar setModulesClaims para todos os usuários autorizados antes de ativar.
      match /ciq-imuno/{lotId} {
        allow read: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && hasModuleAccess('imunologia'));
        allow write: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));

        // /labs/{labId}/ciq-imuno/{lotId}/runs
        match /runs/{runId} {
          allow read: if isSuperAdmin() ||
            (isActiveMemberOfLab(labId) && hasModuleAccess('imunologia'));
          allow create, update: if isSuperAdmin() || isActiveMemberOfLab(labId);
          allow delete: if isSuperAdmin() ||
            (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));
        }

        // /labs/{labId}/ciq-imuno/{lotId}/audit — trilha de auditoria imutável
        match /audit/{auditId} {
          allow read: if isSuperAdmin() ||
            (isActiveMemberOfLab(labId) && hasModuleAccess('imunologia'));
          allow create: if isSuperAdmin() || isActiveMemberOfLab(labId);
          allow update, delete: if false; // registros de auditoria são imutáveis
        }
      }

      // /labs/{labId}/ciq-imuno-meta — contadores e metadados do módulo CIQ-Imuno
      // Counter document: ciq-imuno-meta/counters.runCount (transação para CI-YYYY-NNNN)
      match /ciq-imuno-meta/{docId} {
        allow read: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && hasModuleAccess('imunologia'));
        // Qualquer membro autenticado pode incrementar o contador (via transação)
        allow write: if isSuperAdmin() || isActiveMemberOfLab(labId);
      }

      // /labs/{labId}/ciq-imuno-config — configurações do módulo Imunologia
      // Inclui a lista de tipos de teste (imunoensaios) gerenciável pela UI.
      match /ciq-imuno-config/{docId} {
        allow read: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && hasModuleAccess('imunologia'));
        // Apenas admin/owner podem alterar configurações do módulo
        allow write: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));
      }

      // ── Módulos futuros — adicionar blocos aqui seguindo o mesmo padrão:
      // match /ciq-bioquimica/{lotId} { ... hasModuleAccess('bioquimica') ... }
      // match /ciq-coagulacao/{lotId}  { ... hasModuleAccess('coagulacao')  ... }
      // match /ciq-urinalise/{lotId}   { ... hasModuleAccess('urinalise')   ... }
    }

    // ── /user-data (Legacy) ───────────────────────────────────────────────────

    match /user-data/{uid} {
      allow read, write: if request.auth.uid == uid || isSuperAdmin();
      match /{allSubcollections=**} {
        allow read, write: if request.auth.uid == uid || isSuperAdmin();
      }
    }

    // ── /auditLogs ──────────────────────────────────────────────────────────

    match /auditLogs/{logId} {
      allow create: if isAuthenticated();
      allow read: if isSuperAdmin();
      allow update, delete: if false; // Audit logs are immutable
    }

    // ── /accessRequests ───────────────────────────────────────────────────────

    match /accessRequests/{reqId} {
      allow list, get, update, delete: if isSuperAdmin();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }

    // ── /status ───────────────────────────────────────────────────────────────

    match /status/{docId} {
      allow get: if isAuthenticated();
      allow create: if isAuthenticated() && docId == 'init' &&
        !exists(/databases/$(database)/documents/status/init);
      allow update, delete: if isSuperAdmin();
    }

    // ── /pending_users ────────────────────────────────────────────────────────
    // Stores Google OAuth users who attempted sign-in without a user document.
    // Structure: /pending_users/{labId}/users/{uid}
    //
    // Write: authenticated user can create their own entry (before being signed out).
    // Read/Delete: lab admins/owners and SuperAdmin only.

    match /pending_users/{labId}/users/{uid} {
      // Authenticated user can create their own pending entry while they still
      // hold a valid token (before the client calls signOut).
      allow create: if isAuthenticated() && request.auth.uid == uid;

      // Only lab admins/owners and SuperAdmin can list, read, or delete.
      allow get, list, delete: if isSuperAdmin() || isAdminOrOwner(labId);

      // Updates are performed server-side only (via Cloud Function).
      allow update: if false;
    }
  }
}

