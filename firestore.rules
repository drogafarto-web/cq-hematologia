// в”Ђв”Ђв”Ђ firestore.rules вЂ” versГЈo pГіs-Onda 2 (strict) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
//
// APLICAR APENAS APГ“S:
//   1. `provisionModulesClaims({ dryRun: false })` ter rodado em produГ§ГЈo
//   2. Query de verificaГ§ГЈo (users ativos 30d sem claim `modules`) = 0
//   3. Janela de 48h sem regressГЈo apГіs Onda 2
//
// OperaГ§ГЈo:
//   cp firestore.rules.post-onda2 firestore.rules
//   git commit -m "onda 3: remove module claim bypass"
//   firebase deploy --only firestore:rules --project hcquality-staging
//   # valida 24-48h em staging
//   firebase deploy --only firestore:rules --project hmatologia2
//
// Rollback (se regressГЈo):
//   git revert <sha> + firebase deploy --only firestore:rules
//
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // в”Ђв”Ђ Helpers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return request.auth.token.isSuperAdmin == true ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true);
    }

    function isActiveMemberOfLab(labId) {
      let memberPath = /databases/$(database)/documents/labs/$(labId)/members/$(request.auth.uid);
      return exists(memberPath) && get(memberPath).data.active == true;
    }

    function getMemberRole(labId) {
      return get(/databases/$(database)/documents/labs/$(labId)/members/$(request.auth.uid)).data.role;
    }

    function isAdminOrOwner(labId) {
      let role = getMemberRole(labId);
      return role == 'admin' || role == 'owner';
    }

    // в”Ђв”Ђ Module access (claims obrigatГіrias вЂ” pГіs-provisioning) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    // Onda 2 concluГ­da: todo user ativo tem `modules` no token. Sem bypass.
    function hasModuleAccess(module) {
      return request.auth.token.get('modules', {})[module] == true;
    }

    // в”Ђв”Ђ /users в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    match /users/{userId} {
      allow get: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
      allow list: if isSuperAdmin();
      allow create: if isSuperAdmin() || request.auth.uid == userId;
      allow update: if isSuperAdmin() ||
        (request.auth.uid == userId &&
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['contact', 'displayName', 'photoURL', 'activeLabId', 'pendingLabId']));
      allow delete: if isSuperAdmin();
    }

    // в”Ђв”Ђ /labs в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    match /labs/{labId} {
      allow get: if isSuperAdmin() || isActiveMemberOfLab(labId);
      allow list: if isAuthenticated();
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || isAdminOrOwner(labId);

      match /members/{uid} {
        allow get: if isSuperAdmin() || request.auth.uid == uid || isAdminOrOwner(labId);
        allow list: if isSuperAdmin() || isAdminOrOwner(labId);
        allow write: if isSuperAdmin() || isAdminOrOwner(labId);
      }

      match /data/{dataPath} {
        allow read: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow create, delete: if isSuperAdmin() || isAdminOrOwner(labId);
        allow update: if (isSuperAdmin() || isActiveMemberOfLab(labId)) &&
                       (isAdminOrOwner(labId) || dataPath == 'appState');
      }

      // в”Ђв”Ђ /lots (Hematologia) вЂ” STRICT в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      match /lots/{lotId} {
        allow read: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && hasModuleAccess('hematologia'));
        allow create, update: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow delete: if isSuperAdmin() || (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));

        match /runs/{runId} {
          allow read: if isSuperAdmin() ||
            (isActiveMemberOfLab(labId) && hasModuleAccess('hematologia'));
          allow create, update: if isSuperAdmin() || isActiveMemberOfLab(labId);
          allow delete: if isSuperAdmin() || (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));
        }
      }

      // в”Ђв”Ђ /ciq-imuno вЂ” STRICT в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      match /ciq-imuno/{lotId} {
        allow read: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && hasModuleAccess('imunologia'));
        allow write: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));

        match /runs/{runId} {
          allow read: if isSuperAdmin() ||
            (isActiveMemberOfLab(labId) && hasModuleAccess('imunologia'));
          allow create, update: if isSuperAdmin() || isActiveMemberOfLab(labId);
          allow delete: if isSuperAdmin() ||
            (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));
        }

        match /audit/{auditId} {
          allow read: if isSuperAdmin() ||
            (isActiveMemberOfLab(labId) && hasModuleAccess('imunologia'));
          allow create: if isSuperAdmin() || isActiveMemberOfLab(labId);
          allow update, delete: if false;
        }
      }

      match /ciq-imuno-meta/{docId} {
        allow read: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && hasModuleAccess('imunologia'));
        allow write: if isSuperAdmin() || isActiveMemberOfLab(labId);
      }

      match /ciq-imuno-config/{docId} {
        allow read: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && hasModuleAccess('imunologia'));
        allow write: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));
      }

      // в”Ђв”Ђ /ciq-audit вЂ” create permitido ao membro ativo (legacy) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      // Nota: deleteCIQLot (client) grava audit aqui antes do batch delete
      // para preservar rastro. Triggers da Onda 4 tambГ©m gravam via Admin SDK.
      // Bloquear create completamente quebra o deleteCIQLot вЂ” manter permissГЈo
      // atГ© o caller ser migrado para trigger puro (backlog).
      match /ciq-audit/{docId} {
        allow read: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));
        allow create: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow update, delete: if false;
      }

      match /backup-logs/{logId} {
        allow read:   if isSuperAdmin() || (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));
        allow create: if false;
        allow update, delete: if false;
      }

      // в”Ђв”Ђ /ciq-coagulacao вЂ” STRICT в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      match /ciq-coagulacao/{lotId} {
        allow read: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && hasModuleAccess('coagulacao'));
        allow write: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));

        match /runs/{runId} {
          allow read: if isSuperAdmin() ||
            (isActiveMemberOfLab(labId) && hasModuleAccess('coagulacao'));
          allow create, update: if isSuperAdmin() || isActiveMemberOfLab(labId);
          allow delete: if isSuperAdmin() ||
            (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));
        }

        match /audit/{auditId} {
          allow read: if isSuperAdmin() ||
            (isActiveMemberOfLab(labId) && hasModuleAccess('coagulacao'));
          allow create: if isSuperAdmin() || isActiveMemberOfLab(labId);
          allow update, delete: if false;
        }
      }

      match /ciq-coagulacao-meta/{docId} {
        allow read: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && hasModuleAccess('coagulacao'));
        allow write: if isSuperAdmin() || isActiveMemberOfLab(labId);
      }

      match /ciq-coagulacao-config/{docId} {
        allow read: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && hasModuleAccess('coagulacao'));
        allow write: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));
      }

      match /ciq-coagulacao-audit/{docId} {
        allow read: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));
        allow create: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow update, delete: if false;
      }

      // в”Ђв”Ђ /ciq-uroanalise вЂ” STRICT в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      match /ciq-uroanalise/{lotId} {
        allow read: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && hasModuleAccess('uroanalise'));
        allow write: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));

        match /runs/{runId} {
          allow read: if isSuperAdmin() ||
            (isActiveMemberOfLab(labId) && hasModuleAccess('uroanalise'));
          allow create, update: if isSuperAdmin() || isActiveMemberOfLab(labId);
          allow delete: if isSuperAdmin() ||
            (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));
        }

        match /audit/{auditId} {
          allow read: if isSuperAdmin() ||
            (isActiveMemberOfLab(labId) && hasModuleAccess('uroanalise'));
          allow create: if isSuperAdmin() || isActiveMemberOfLab(labId);
          allow update, delete: if false;
        }
      }

      match /ciq-uroanalise-meta/{docId} {
        allow read: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && hasModuleAccess('uroanalise'));
        allow write: if isSuperAdmin() || isActiveMemberOfLab(labId);
      }

      match /ciq-uroanalise-config/{docId} {
        allow read: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && hasModuleAccess('uroanalise'));
        allow write: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));
      }

      match /ciq-uroanalise-audit/{docId} {
        allow read: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));
        allow create: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow update, delete: if false;
      }

      // в”Ђв”Ђ Produtos de Insumo, Equipamentos, etc вЂ” inalterados (sem gate de mГіdulo) в”Ђв”Ђ
      match /produtos-insumos/{produtoId} {
        allow read: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow create, update: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow delete: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));
      }

      match /equipamentos/{equipamentoId} {
        allow read: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow create, update: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow delete: if false;
      }

      match /equipamentos-audit/{auditId} {
        allow read: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow create: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow update, delete: if false;
      }

      match /fornecedores/{fornecedorId} {
        allow read: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow create, update: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow delete: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));
      }

      match /notas-fiscais/{notaId} {
        allow read: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow create, update: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow delete: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));
      }

      match /insumos/{insumoId} {
        allow read: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow create, update: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow delete: if isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && isAdminOrOwner(labId));
      }

      match /equipment-setups/{module} {
        allow read: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow create, update: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow delete: if false;
      }

      match /insumo-transitions/{transitionId} {
        allow read: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow create: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow update, delete: if false;
      }

      match /fr10-emissions/{hash} {
        function isValidEmission(d) {
          return d.hash is string
              && d.hash == hash
              && d.hash.size() == 64
              && d.labId == labId
              && d.labName is string
              && d.modulo is string
              && d.equipamento is string
              && d.periodoInicio is timestamp
              && d.periodoFim is timestamp
              && d.emittedAt is timestamp
              && d.emittedByUid is string
              && d.emittedByName is string
              && d.rowCount is int
              && d.rowCount >= 0;
        }

        allow read: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow create: if (isSuperAdmin() || isActiveMemberOfLab(labId))
                      && isValidEmission(request.resource.data);
        allow update: if (isSuperAdmin() || isActiveMemberOfLab(labId))
                      && request.resource.data.hash == resource.data.hash
                      && request.resource.data.labId == resource.data.labId
                      && request.resource.data.emittedAt == resource.data.emittedAt;
        allow delete: if false;
      }

      // EmissГµes de RelatГіrio CQI вЂ” RDC 978/2025 (ver firestore.rules para doc).
      match /report-emissions/{emissionId} {
        function isValidReportEmission(d) {
          return d.labId == labId
              && d.emissionId == emissionId
              && d.auditCode is string
              && d.auditCode.size() >= 16
              && d.payloadHash is string
              && d.payloadHash.size() == 64
              && d.scope is string
              && d.generatedAt is timestamp
              && d.generatedBy is string
              && d.generatedBy == request.auth.uid
              && d.lotIds is list
              && d.runIds is list
              && d.runCount is int
              && d.runCount >= 0;
        }

        allow read: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow create: if (isSuperAdmin() || isActiveMemberOfLab(labId))
                      && isValidReportEmission(request.resource.data);
        allow update, delete: if false;
      }

      match /insumo-movimentacoes/{movId} {
        function hasValidInitialChain(d) {
          return d.payloadSignature is string
              && d.payloadSignature.size() == 64
              && d.chainHash == null
              && d.chainStatus == 'pending'
              && !('sealedAt' in d)
              && d.insumoId is string
              && d.operadorId is string
              && d.clientTimestamp is string;
        }

        allow read: if isSuperAdmin() || isActiveMemberOfLab(labId);
        allow create: if (isSuperAdmin() || isActiveMemberOfLab(labId))
                      && hasValidInitialChain(request.resource.data);
        allow update, delete: if false;
      }
    }

    // в”Ђв”Ђ Raiz вЂ” inalterados в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

    match /firestore-backup-logs/{logId} {
      allow read:   if isSuperAdmin();
      allow create, update, delete: if false;
    }

    match /user-data/{uid} {
      allow read, write: if request.auth.uid == uid || isSuperAdmin();
      match /{allSubcollections=**} {
        allow read, write: if request.auth.uid == uid || isSuperAdmin();
      }
    }

    match /auditLogs/{logId} {
      allow create: if isAuthenticated();
      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /accessRequests/{reqId} {
      allow list, get, update, delete: if isSuperAdmin();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }

    match /status/{docId} {
      allow get: if isAuthenticated();
      allow create: if isAuthenticated() && docId == 'init' &&
        !exists(/databases/$(database)/documents/status/init);
      allow update, delete: if isSuperAdmin();
    }

    match /pending_users/{labId}/users/{uid} {
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow get, list, delete: if isSuperAdmin() || isAdminOrOwner(labId);
      allow update: if false;
    }

    // в”Ђв”Ђ /controleTemperatura вЂ” FR-11 / PQ-06 (RDC 978/2025 + ISO 15189:2022 cl. 5.3) в”Ђв”Ђ
    //
    // Path de topo com {labId} como doc raiz вЂ” mesmo padrГЈo do mГіdulo EC.
    // Gate por `isActiveMemberOfLab` apenas (sem `hasModuleAccess`) porque
    // 'controle-temperatura' ainda nГЈo estГЎ em `MODULE_CLAIMS` no constants.ts.
    // Upgrade pra module-gated = dГ©bito CT-07; quando chegar, seguir a mesma
    // sequГЄncia de Ondas do EC: 1) estender provisionModulesClaims, 2) rodar
    // em prod, 3) verificar 0 usuГЎrios ativos sem claim, 4) deploy destas rules.
    //
    // Schema strict + assinatura validada em leituras/ncs previne forja
    // cliente-side. DeleГ§ГЈo sempre lГіgica (RN-07, guarda 5 anos).
    // Dispositivos IoT (tokens) restritos a admin/owner вЂ” raio do blast
    // de token comprometido Г© um equipamento inteiro.
    match /controleTemperatura/{labId} {
      // Doc raiz вЂ” Гўncora sem dados prГіprios.
      allow read: if isSuperAdmin() || isActiveMemberOfLab(labId);
      allow create, update: if (isSuperAdmin() || isActiveMemberOfLab(labId))
                            && request.resource.data.keys().hasOnly(['labId'])
                            && request.resource.data.labId == labId;
      allow delete: if false;

      // в”Ђв”Ђ Helpers locais в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      function canReadCt() {
        return isSuperAdmin() || isActiveMemberOfLab(labId);
      }
      function canWriteCt() {
        return isSuperAdmin() || isActiveMemberOfLab(labId);
      }
      function canAdminCt() {
        return isSuperAdmin() || isAdminOrOwner(labId);
      }
      function ctLabIdMatches(d) {
        return d.labId == labId;
      }
      function ctValidSignature(d) {
        return d.assinatura is map
            && d.assinatura.hash is string
            && d.assinatura.hash.size() == 64
            && d.assinatura.operatorId == request.auth.uid
            && d.assinatura.ts is timestamp;
      }
      // Update: assinatura idГЄntica OU substituГ­da por outra vГЎlida do user.
      function ctAssinaturaOkUpdate() {
        return request.resource.data.assinatura == resource.data.assinatura
            || ctValidSignature(request.resource.data);
      }
      function ctKeepsLabId() {
        return request.resource.data.labId == resource.data.labId;
      }

      // в”Ђв”Ђ Equipamentos в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      match /equipamentos/{id} {
        allow read: if canReadCt();
        allow create: if canWriteCt()
                      && ctLabIdMatches(request.resource.data)
                      && request.resource.data.deletadoEm == null
                      && request.resource.data.nome is string
                      && request.resource.data.tipo in ['geladeira', 'freezer', 'freezer_ultrabaixo', 'sala', 'banho_maria', 'estufa', 'incubadora', 'outro']
                      && request.resource.data.status in ['ativo', 'manutencao', 'inativo']
                      && request.resource.data.termometroId is string
                      && request.resource.data.limites is map
                      && request.resource.data.limites.temperaturaMin is number
                      && request.resource.data.limites.temperaturaMax is number
                      && request.resource.data.limites.temperaturaMin < request.resource.data.limites.temperaturaMax;
        allow update: if canWriteCt()
                      && ctKeepsLabId()
                      && request.resource.data.criadoEm == resource.data.criadoEm;
        allow delete: if false;
      }

      // в”Ђв”Ђ Leituras в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      // Manual: origem='manual' + assinatura obrigatГіria (RN-02).
      // IoT: origem='automatica_iot' вЂ” gravaГ§ГЈo pela Cloud Function com
      // Admin SDK bypassa rules. Client-side nГЈo consegue criar leitura IoT
      // sem assinatura вЂ” safe by construction.
      match /leituras/{id} {
        allow read: if canReadCt();
        allow create: if canWriteCt()
                      && ctLabIdMatches(request.resource.data)
                      && request.resource.data.deletadoEm == null
                      && request.resource.data.equipamentoId is string
                      && request.resource.data.dataHora is timestamp
                      && request.resource.data.temperaturaAtual is number
                      && request.resource.data.origem == 'manual'
                      && request.resource.data.status in ['realizada', 'perdida', 'justificada']
                      && ctValidSignature(request.resource.data);
        allow update: if canWriteCt()
                      && ctKeepsLabId()
                      && resource.data.equipamentoId == request.resource.data.equipamentoId
                      && ctAssinaturaOkUpdate();
        allow delete: if false;
      }

      // в”Ђв”Ђ Leituras Previstas в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      // CriaГ§ГЈo primГЎria via scheduled function (Admin SDK bypassa rules).
      // Client-side pode marcar como justificada/perdida manualmente.
      match /leituras-previstas/{id} {
        allow read: if canReadCt();
        allow create: if canWriteCt()
                      && ctLabIdMatches(request.resource.data)
                      && request.resource.data.equipamentoId is string
                      && request.resource.data.dataHoraPrevista is timestamp
                      && request.resource.data.status in ['pendente', 'realizada', 'perdida', 'justificada'];
        allow update: if canWriteCt()
                      && ctKeepsLabId()
                      && resource.data.equipamentoId == request.resource.data.equipamentoId
                      && resource.data.dataHoraPrevista == request.resource.data.dataHoraPrevista;
        allow delete: if false;
      }

      // в”Ђв”Ђ NГЈo Conformidades в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      // CriaГ§ГЈo primГЎria: batch da leitura fora dos limites (RN-01).
      // Cliente tambГ©m pode criar NC manual вЂ” caso de desvio observado
      // sem leitura registrada ainda. Assinatura sempre obrigatГіria.
      match /ncs/{id} {
        allow read: if canReadCt();
        allow create: if canWriteCt()
                      && ctLabIdMatches(request.resource.data)
                      && request.resource.data.deletadoEm == null
                      && request.resource.data.equipamentoId is string
                      && request.resource.data.temperaturaRegistrada is number
                      && request.resource.data.limiteViolado in ['max', 'min', 'umidade']
                      && request.resource.data.status in ['aberta', 'em_andamento', 'resolvida']
                      && ctValidSignature(request.resource.data);
        allow update: if canWriteCt()
                      && ctKeepsLabId()
                      && resource.data.equipamentoId == request.resource.data.equipamentoId
                      && resource.data.leituraId == request.resource.data.leituraId
                      && ctAssinaturaOkUpdate()
                      && request.resource.data.status in ['aberta', 'em_andamento', 'resolvida'];
        allow delete: if false;
      }

      // в”Ђв”Ђ TermГґmetros в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      // Schema v2 (2026-04-24): calibraГ§ГЈo encadeada com histГіrico imutГЎvel.
      // `calibracaoAtual` sempre presente (versГЈo vigente); `historicoCalibracoes`
      // append-only вЂ” renovaГ§ГЈo arquiva versГЈo anterior mas jamais remove.
      // RN-09 Г© implementada client-side via transaction (nГЈo Г© possГ­vel validar
      // monotonia do histГіrico em rules). ProteГ§Гµes aqui: soft-delete only,
      // labId imutГЎvel, criadoEm imutГЎvel.
      match /termometros/{id} {
        allow read: if canReadCt();
        allow create: if canWriteCt()
                      && ctLabIdMatches(request.resource.data)
                      && request.resource.data.deletadoEm == null
                      && request.resource.data.numeroSerie is string
                      && request.resource.data.incertezaMedicao is number
                      && request.resource.data.calibracaoAtual is map
                      && request.resource.data.calibracaoAtual.versao is number
                      && request.resource.data.calibracaoAtual.dataEmissao is timestamp
                      && request.resource.data.calibracaoAtual.dataValidade is timestamp
                      && request.resource.data.calibracaoAtual.numeroCertificado is string
                      && request.resource.data.calibracaoAtual.laboratorioCalibrador is string
                      && request.resource.data.historicoCalibracoes is list
                      && request.resource.data.ativo is bool;
        allow update: if canWriteCt()
                      && ctKeepsLabId()
                      && request.resource.data.criadoEm == resource.data.criadoEm
                      && request.resource.data.calibracaoAtual is map
                      && request.resource.data.historicoCalibracoes is list
                      && request.resource.data.historicoCalibracoes.size() >= resource.data.historicoCalibracoes.size();
        allow delete: if false;
      }

      // в”Ђв”Ђ Dispositivos IoT в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      // Escrita restrita a admin/owner вЂ” blast radius de token comprometido
      // Г© 1 equipamento (leituras falsas + NCs falsas). Leitura por qualquer
      // membro ativo (dashboard mostra status online/offline).
      //
      // `ultimaTransmissao`/`online` sГЈo atualizados pela Cloud Function
      // registrarLeituraIoT via Admin SDK вЂ” bypassa estas rules.
      match /dispositivos-iot/{id} {
        allow read: if canReadCt();
        allow create: if canAdminCt()
                      && ctLabIdMatches(request.resource.data)
                      && request.resource.data.deletadoEm == null
                      && request.resource.data.equipamentoId is string
                      && request.resource.data.macAddress is string
                      && request.resource.data.tokenAcesso is string
                      && request.resource.data.tokenAcesso.size() == 64
                      && request.resource.data.intervaloEnvioMinutos is number
                      && request.resource.data.ativo is bool;
        allow update: if canAdminCt()
                      && ctKeepsLabId()
                      && resource.data.tokenAcesso == request.resource.data.tokenAcesso
                      && resource.data.equipamentoId == request.resource.data.equipamentoId;
        allow delete: if false;
      }
    }

    // в”Ђв”Ђ /educacaoContinuada вЂ” FR-001 / FR-013 / FR-027 (RDC 978/2025 + ISO 15189:2022) в”Ђв”Ђ
    //
    // MГіdulo Гєnico deste feature. Path de topo com {labId} como doc raiz вЂ”
    // decisГЈo explГ­cita do CTO, diverge do padrГЈo /labs/{labId}/<coleГ§ГЈo>/
    // dos demais mГіdulos. Doc raiz Г© mera Гўncora, sem dados prГіprios.
    //
    // Ordem obrigatГіria de deploy:
    //   1. Estender `provisionModulesClaims` para incluir 'educacao-continuada'
    //   2. Rodar com dryRun=false em prod (grant claim a todos os users ativos)
    //   3. Verificar com query: usuГЎrios ativos 30d sem o claim 'educacao-continuada' = 0
    //   4. Deploy destas rules
    //
    // Sem o passo 1-2, `hasModuleAccess('educacao-continuada')` retorna false
    // para 100% dos users e o mГіdulo fica inacessГ­vel вЂ” fail-safe intencional.
    match /educacaoContinuada/{labId} {
      // Doc raiz вЂ” Гўncora sem dados prГіprios. Payload apenas { labId } para
      // permitir que rules de subcoleГ§ГЈo resolvam o labId do path.
      allow read: if isSuperAdmin() || isActiveMemberOfLab(labId);
      allow create, update: if (isSuperAdmin() || isActiveMemberOfLab(labId))
                            && request.resource.data.keys().hasOnly(['labId'])
                            && request.resource.data.labId == labId;
      allow delete: if false;

      // в”Ђв”Ђ Helpers locais в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      function canReadEc() {
        return isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && hasModuleAccess('educacao-continuada'));
      }
      function canWriteEc() {
        return isSuperAdmin() ||
          (isActiveMemberOfLab(labId) && hasModuleAccess('educacao-continuada'));
      }
      function labIdMatches(d) {
        return d.labId == labId;
      }
      // Assinatura vГЎlida: hash SHA-256 hex de 64 chars, operatorId obrigatoriamente
      // == request.auth.uid (impede forjar assinatura em nome de outro usuГЎrio).
      function validSignature(d) {
        return d.assinatura is map
            && d.assinatura.hash is string
            && d.assinatura.hash.size() == 64
            && d.assinatura.operatorId == request.auth.uid
            && d.assinatura.ts is timestamp;
      }
      // Em update: a assinatura Г© substituГ­da por uma nova (vГЎlida pelo user
      // logado) OU preservada idГЄntica. Impede forjar e impede "dessassinar".
      function assinaturaOkUpdate() {
        return request.resource.data.assinatura == resource.data.assinatura
            || validSignature(request.resource.data);
      }
      function keepsCreatedAt() {
        return request.resource.data.criadoEm == resource.data.criadoEm;
      }
      function keepsLabId() {
        return request.resource.data.labId == resource.data.labId;
      }

      // в”Ђв”Ђ Colaboradores в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      match /colaboradores/{id} {
        allow read: if canReadEc();
        allow create: if canWriteEc()
                      && labIdMatches(request.resource.data)
                      && request.resource.data.deletadoEm == null
                      && request.resource.data.nome is string
                      && request.resource.data.cargo is string
                      && request.resource.data.setor is string
                      && request.resource.data.ativo is bool;
        allow update: if canWriteEc()
                      && keepsLabId()
                      && keepsCreatedAt();
        allow delete: if false;  // Soft delete only (RN-06)
      }

      // в”Ђв”Ђ Treinamentos (FR-027) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      match /treinamentos/{id} {
        allow read: if canReadEc();
        allow create: if canWriteEc()
                      && labIdMatches(request.resource.data)
                      && request.resource.data.deletadoEm == null
                      && request.resource.data.titulo is string
                      && request.resource.data.cargaHoraria is number
                      && request.resource.data.cargaHoraria > 0
                      && request.resource.data.modalidade in ['presencial', 'online', 'em_servico']
                      && request.resource.data.unidade in ['fixa', 'itinerante', 'ambas']
                      && request.resource.data.periodicidade in ['mensal', 'bimestral', 'trimestral', 'semestral', 'anual']
                      && request.resource.data.ativo is bool;
        allow update: if canWriteEc()
                      && keepsLabId()
                      && keepsCreatedAt();
        allow delete: if false;
      }

      // в”Ђв”Ђ ExecuГ§Гµes (FR-001) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      // Fase 0c (2026-04-24): escritas regulatГіrias (realizado/adiado) movidas
      // para callables `ec_commitExecucaoRealizada`/`ec_commitExecucaoAdiada`
      // (Admin SDK bypassa rules). Client-side fica restrito a:
      //   - create status='planejado' (via ExecucaoForm / Import XLSX)
      //   - update metadata em planejado (ediГ§ГЈo simples)
      //   - transiГ§ГЈo planejadoв†’cancelado (cancelamento trivial, sem cascade)
      //   - soft-delete (diff apenas em deletadoEm)
      match /execucoes/{id} {
        allow read: if canReadEc();
        allow create: if canWriteEc()
                      && labIdMatches(request.resource.data)
                      && request.resource.data.deletadoEm == null
                      && request.resource.data.treinamentoId is string
                      && request.resource.data.status == 'planejado'
                      && request.resource.data.dataPlanejada is timestamp
                      && validSignature(request.resource.data);
        allow update: if canWriteEc()
                      && keepsLabId()
                      && keepsCreatedAt()
                      && resource.data.treinamentoId == request.resource.data.treinamentoId
                      && assinaturaOkUpdate()
                      && (
                        // (a) soft-delete/restore: sГі deletadoEm muda
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletadoEm'])
                        ||
                        // (b) ediГ§ГЈo em planejado, com transiГ§ГЈo opcional para cancelado
                        (
                          resource.data.status == 'planejado'
                          && request.resource.data.status in ['planejado', 'cancelado']
                        )
                      );
        allow delete: if false;
      }

      // в”Ђв”Ђ Participantes в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      // Fase 0c: escrita exclusiva do callable `ec_commitExecucaoRealizada`
      // (Admin SDK bypassa rules). Client nГЈo tem caminho legГ­timo para criar
      // participante direto вЂ” tentar fazГЄ-lo Г© tentativa de adulterar RN-03.
      // Update do cliente restrito a soft-delete/restore (diff em deletadoEm).
      match /participantes/{id} {
        allow read: if canReadEc();
        allow create: if false;
        allow update: if canWriteEc()
                      && keepsLabId()
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletadoEm']);
        allow delete: if false;
      }

      // в”Ђв”Ђ AvaliaГ§ГЈo de EficГЎcia (FR-001 bloco inferior + FR-013) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      // Fase 0c: escrita exclusiva dos callables `ec_registrarAvaliacaoEficacia`
      // + `ec_fecharAvaliacaoEficacia` (servidor aplica RN-02 autoritativamente).
      // Client mantГ©m apenas soft-delete/restore via hook.
      match /avaliacoesEficacia/{id} {
        allow read: if canReadEc();
        allow create: if false;
        allow update: if canWriteEc()
                      && keepsLabId()
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletadoEm']);
        allow delete: if false;
      }

      // в”Ђв”Ђ AvaliaГ§ГЈo de CompetГЄncia (ISO 15189:2022 cl. 6.2.4) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      // Fase 0c: escrita exclusiva do callable `ec_registrarAvaliacaoCompetencia`
      // (servidor valida FK Participanteв†’Execucao `presente=true` + injeta
      // avaliadorId=auth.uid). Client mantГ©m apenas soft-delete/restore.
      match /avaliacoesCompetencia/{id} {
        allow read: if canReadEc();
        allow create: if false;
        allow update: if canWriteEc()
                      && keepsLabId()
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deletadoEm']);
        allow delete: if false;
      }

      // в”Ђв”Ђ Alertas de Vencimento (RN-05) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      // Fase 0c: criaГ§ГЈo exclusiva do callable `ec_commitExecucaoRealizada`
      // (atomic com execuГ§ГЈo realizada + participantes). Client mantГ©m apenas
      // transiГ§ГЈo de status (marcar notificado/resolvido/reabrir) via
      // `useAlertasVencimento`, sem conseguir backdating de dataVencimento.
      match /alertasVencimento/{id} {
        allow read: if canReadEc();
        allow create: if false;
        allow update: if canWriteEc()
                      && keepsLabId()
                      && resource.data.treinamentoId == request.resource.data.treinamentoId
                      && resource.data.dataVencimento == request.resource.data.dataVencimento
                      && resource.data.diasAntecedencia == request.resource.data.diasAntecedencia
                      && request.resource.data.status in ['pendente', 'notificado', 'resolvido'];
        allow delete: if false;
      }

      // в”Ђв”Ђ FASE 6 вЂ” Templates de treinamento (biblioteca reutilizГЎvel) в”Ђв”Ђ
      // NГЈo-regulatГіrio: cadastro administrativo. Writes client-side mantidos.
      // `versao` = contador incremental (service faz +1 em cada update);
      // `materialDidatico` Г© array de MaterialDidatico inline no doc.
      match /templates/{id} {
        allow read: if canReadEc();
        allow create: if canWriteEc()
                      && labIdMatches(request.resource.data)
                      && request.resource.data.deletadoEm == null
                      && request.resource.data.titulo is string
                      && request.resource.data.tema is string
                      && request.resource.data.objetivo is string
                      && request.resource.data.cargaHoraria is number
                      && request.resource.data.cargaHoraria > 0
                      && request.resource.data.modalidade in ['presencial', 'online', 'em_servico']
                      && request.resource.data.periodicidade in ['mensal', 'bimestral', 'trimestral', 'semestral', 'anual']
                      && request.resource.data.pauta is string
                      && request.resource.data.tags is list
                      && request.resource.data.versao is int
                      && request.resource.data.versao == 1
                      && request.resource.data.materialDidatico is list
                      && request.resource.data.ativo is bool;
        allow update: if canWriteEc()
                      && keepsLabId()
                      && keepsCreatedAt();
        allow delete: if false;
      }

      // в”Ђв”Ђ FASE 6 вЂ” Kits de IntegraГ§ГЈo в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      // SequГЄncia ordenada de templates por cargo (ex: "Kit BiomГ©dico JГєnior").
      // NГЈo-regulatГіrio.
      match /kitsIntegracao/{id} {
        allow read: if canReadEc();
        allow create: if canWriteEc()
                      && labIdMatches(request.resource.data)
                      && request.resource.data.deletadoEm == null
                      && request.resource.data.nome is string
                      && request.resource.data.cargo is string
                      && request.resource.data.templateIds is list
                      && request.resource.data.ativo is bool;
        allow update: if canWriteEc()
                      && keepsLabId()
                      && keepsCreatedAt();
        allow delete: if false;
      }

      // в”Ђв”Ђ FASE 7 вЂ” Trilhas de Aprendizado (RN-08) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      match /trilhas/{id} {
        allow read: if canReadEc();
        allow create: if canWriteEc()
                      && labIdMatches(request.resource.data)
                      && request.resource.data.deletadoEm == null
                      && request.resource.data.nome is string
                      && request.resource.data.cargo is string
                      && request.resource.data.etapas is list
                      && request.resource.data.ativo is bool;
        allow update: if canWriteEc()
                      && keepsLabId()
                      && keepsCreatedAt();
        allow delete: if false;
      }

      // в”Ђв”Ђ FASE 7 вЂ” ProgressoTrilha (1 por colaboradorГ—trilha) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      // Criado por hook RN-08 ou manualmente pelo responsГЎvel. NГЈo-regulatГіrio
      // per se (o registro regulatГіrio fica em AvaliacaoCompetencia); este
      // rastreia apenas andamento do onboarding.
      match /progressosTrilha/{id} {
        allow read: if canReadEc();
        allow create: if canWriteEc()
                      && labIdMatches(request.resource.data)
                      && request.resource.data.deletadoEm == null
                      && request.resource.data.colaboradorId is string
                      && request.resource.data.trilhaId is string
                      && request.resource.data.dataInicio is timestamp
                      && request.resource.data.status in ['em_andamento', 'concluida', 'pausada']
                      && request.resource.data.etapas is list
                      && request.resource.data.percentualConcluido is int;
        allow update: if canWriteEc()
                      && keepsLabId()
                      && resource.data.colaboradorId == request.resource.data.colaboradorId
                      && resource.data.trilhaId == request.resource.data.trilhaId;
        allow delete: if false;
      }

      // в”Ђв”Ђ FASE 8 вЂ” QuestГµes (public, sem gabarito) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      // Escrita via callable `ec_criarQuestao` (Admin SDK bypassa rules).
      // Client sГі lГЄ + archive (toggle ativo=false).
      match /questoes/{id} {
        allow read: if canReadEc();
        allow create: if false;
        allow update: if canWriteEc()
                      && keepsLabId()
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ativo']);
        allow delete: if false;
      }

      // в”Ђв”Ђ FASE 8 вЂ” Gabarito (SERVER-ONLY вЂ” client nunca lГЄ) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      // ContГ©m respostas corretas. RN-10: Firestore rules bloqueiam leitura
      // client totalmente. Callables (Admin SDK) lГЄem para correГ§ГЈo.
      match /questoesGabarito/{id} {
        allow read: if false;
        allow write: if false;
      }

      // в”Ђв”Ђ FASE 8 вЂ” AvaliacaoTeste (escrita via callable) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      match /avaliacoesTeste/{id} {
        allow read: if canReadEc();
        allow write: if false;
      }

      // в”Ђв”Ђ FASE 8 вЂ” RespostaAvaliacao (escrita via callable) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      match /respostasAvaliacao/{id} {
        allow read: if canReadEc();
        allow write: if false;
      }

      // в”Ђв”Ђ FASE 9 вЂ” Certificado (escrita via callable) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      match /certificados/{id} {
        allow read: if canReadEc();
        allow write: if false;
      }

      // в”Ђв”Ђ FASE 9 вЂ” CertificadoConfig (singleton por lab) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      match /certificadoConfig/{id} {
        allow read: if canReadEc();
        allow write: if canWriteEc()
                     && request.resource.data.labId == labId
                     && request.resource.data.nomeDoLab is string
                     && request.resource.data.textoRodape is string;
      }

      // в”Ђв”Ђ FASE 9 вЂ” ConfiguracaoAlerta (singleton por lab) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
      match /configAlertas/{id} {
        allow read: if canReadEc();
        allow write: if canWriteEc()
                     && request.resource.data.labId == labId
                     && request.resource.data.diasAntecedenciaVencimento is int
                     && request.resource.data.diasAntecedenciaVencimento >= 0
                     && request.resource.data.diasAntecedenciaVencimento <= 365
                     && request.resource.data.emailResponsavel is bool
                     && request.resource.data.emailColaborador is bool
                     && request.resource.data.horaEnvio is string;
      }
    }
  }
}
