# Firebase — obter em: Firebase Console > Configurações do projeto > Seus aplicativos
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Provedor de banco de dados: "firebase" (produção) | "local" (dev offline)
VITE_DATABASE_PROVIDER=firebase

# Firestore: força long-polling (menos sensível a bloqueio de WebChannel por extensões).
# Requer rebuild. Ver docs/CEQ_FIRESTORE_TRANSPORT_TROUBLESHOOTING.md
# VITE_FIRESTORE_USE_LONG_POLLING=true

# URL base para QR Codes de auditoria (opcional — tem fallback para cq.labclin.com.br/audit)
# Sobrescrever em produção se o domínio for diferente
VITE_AUDIT_BASE_URL=

# Gemini API Key — NÃO vai mais aqui.
# A chave é armazenada como Firebase Secret no servidor.
# Para configurar: firebase secrets:set GEMINI_API_KEY
# Docs: https://firebase.google.com/docs/functions/config-env#secret-manager

# Sentry (error tracking + session replay)
# DSN é público, OK no .env. Auth token vai em .env.local (gitignored).
VITE_SENTRY_DSN=
# Apenas em .env.local (CI lê do GitHub Secrets):
# SENTRY_AUTH_TOKEN=
