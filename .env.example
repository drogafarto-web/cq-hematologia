# Firebase — obter em: Firebase Console > Configurações do projeto > Seus aplicativos
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Provedor de banco de dados: "firebase" (produção) | "local" (dev offline)
VITE_DATABASE_PROVIDER=firebase

# Gemini API Key — NÃO vai mais aqui.
# A chave é armazenada como Firebase Secret no servidor.
# Para configurar: firebase secrets:set GEMINI_API_KEY
# Docs: https://firebase.google.com/docs/functions/config-env#secret-manager
