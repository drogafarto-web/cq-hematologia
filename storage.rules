rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Lab files: isolated per tenant ────────────────────────────────────────
    // All lab assets live under labs/{labId}/. Access is gated by the
    // /labs/{labId}/members/{uid} Firestore subcollection (same RBAC as Firestore rules).

    match /labs/{labId}/{allPaths=**} {

      function isAuth() {
        return request.auth != null;
      }

      function isSuperAdmin() {
        return isAuth() &&
          firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true;
      }

      function isActiveMember() {
        let memberPath = /databases/(default)/documents/labs/$(labId)/members/$(request.auth.uid);
        return isAuth() &&
          firestore.exists(memberPath) &&
          firestore.get(memberPath).data.active == true;
      }

      function getMemberRole() {
        return firestore.get(
          /databases/(default)/documents/labs/$(labId)/members/$(request.auth.uid)
        ).data.role;
      }

      function isAdminOrOwner() {
        let role = getMemberRole();
        return role == 'admin' || role == 'owner';
      }

      // Any active member (or superAdmin) can read files in their lab
      allow read: if isSuperAdmin() || isActiveMember();

      // Logo and admin-level files: only admin/owner can write
      allow write: if isSuperAdmin() || (isActiveMember() && isAdminOrOwner());
    }

    // ── Lab-apoio: contract PDFs (Phase 0 / Plan 00-03) ──────────────────────────
    // Path: labs/{labId}/lab-apoio/{contratoId}/contrato.pdf
    // Signed URLs generated by labApoio_uploadContratoAnexo callable for public link.
    // Storage rules enforce: admin/owner write only, PDF only, <10MB.
    match /labs/{labId}/lab-apoio/{contratoId}/{filename} {

      function isAuth() {
        return request.auth != null;
      }

      function hasLabApoioModuleClaim() {
        return isAuth() &&
          request.auth.token.modules != null &&
          request.auth.token.modules['lab-apoio'] == true;
      }

      function isActiveMember() {
        let memberPath = /databases/(default)/documents/labs/$(labId)/members/$(request.auth.uid);
        return isAuth() &&
          firestore.exists(memberPath) &&
          firestore.get(memberPath).data.active == true;
      }

      function isAdminOrOwner() {
        let role = firestore.get(
          /databases/(default)/documents/labs/$(labId)/members/$(request.auth.uid)
        ).data.role;
        return role == 'admin' || role == 'owner';
      }

      function isSuperAdmin() {
        return isAuth() &&
          firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true;
      }

      function isPdfOnly() {
        return request.resource.contentType == 'application/pdf';
      }

      function isUnderLimit() {
        return request.resource.size <= 10 * 1024 * 1024; // 10MB
      }

      allow read: if isSuperAdmin() || (hasLabApoioModuleClaim() && isActiveMember());

      allow create, update: if (isSuperAdmin() || (hasLabApoioModuleClaim() && isActiveMember() && isAdminOrOwner()))
                            && isPdfOnly()
                            && isUnderLimit();

      allow delete: if isSuperAdmin() || (hasLabApoioModuleClaim() && isActiveMember() && isAdminOrOwner());
    }

    // ── Run images: any active member can upload, only admin/owner can delete ─
    // This more-specific match extends the write permission for the runs path.
    // Firebase Storage uses OR semantics across match blocks, so create/update
    // access is granted to all members here, while delete remains restricted.

    match /labs/{labId}/lots/{lotId}/runs/{runId} {

      function isAuth() {
        return request.auth != null;
      }

      function isSuperAdmin() {
        return isAuth() &&
          firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true;
      }

      function isActiveMember() {
        let memberPath = /databases/(default)/documents/labs/$(labId)/members/$(request.auth.uid);
        return isAuth() &&
          firestore.exists(memberPath) &&
          firestore.get(memberPath).data.active == true;
      }

      function getMemberRole() {
        return firestore.get(
          /databases/(default)/documents/labs/$(labId)/members/$(request.auth.uid)
        ).data.role;
      }

      function isAdminOrOwner() {
        let role = getMemberRole();
        return role == 'admin' || role == 'owner';
      }

      allow read:          if isSuperAdmin() || isActiveMember();
      allow create, update: if isSuperAdmin() || isActiveMember();
      allow delete:        if isSuperAdmin() || (isActiveMember() && isAdminOrOwner());
    }

    // ── Controle de Temperatura: certificados de calibração de termômetros ──
    // Qualquer membro ativo pode ler + anexar certificados. Apenas admin/owner
    // pode deletar — mesmo modelo defensivo das imagens de runs. Path
    // segue o padrão `labs/{labId}/controle-temperatura/calibracoes/{file}`.
    match /labs/{labId}/controle-temperatura/{allPaths=**} {

      function isAuth() {
        return request.auth != null;
      }

      function isSuperAdmin() {
        return isAuth() &&
          firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true;
      }

      function isActiveMember() {
        let memberPath = /databases/(default)/documents/labs/$(labId)/members/$(request.auth.uid);
        return isAuth() &&
          firestore.exists(memberPath) &&
          firestore.get(memberPath).data.active == true;
      }

      function getMemberRole() {
        return firestore.get(
          /databases/(default)/documents/labs/$(labId)/members/$(request.auth.uid)
        ).data.role;
      }

      function isAdminOrOwner() {
        let role = getMemberRole();
        return role == 'admin' || role == 'owner';
      }

      allow read:          if isSuperAdmin() || isActiveMember();
      allow create, update: if isSuperAdmin() || isActiveMember();
      allow delete:        if isSuperAdmin() || (isActiveMember() && isAdminOrOwner());
    }

    // ── PR1 (2026-04-26) — anexos de qualificação de insumos ─────────────────
    // Anexos opcionais (foto de embalagem, PDF de NF, certificado de análise).
    // Read: qualquer membro ativo. Write: apenas admin/owner (proxy RT/biomedico
    // — modelo de roles atual não distingue cargo). Delete bloqueado: anexos de
    // qualificação são prova regulatória (RDC 786 art. 42) e devem permanecer.
    match /labs/{labId}/qualificacoes/{allPaths=**} {

      function isAuth() {
        return request.auth != null;
      }

      function isSuperAdmin() {
        return isAuth() &&
          firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true;
      }

      function isActiveMember() {
        let memberPath = /databases/(default)/documents/labs/$(labId)/members/$(request.auth.uid);
        return isAuth() &&
          firestore.exists(memberPath) &&
          firestore.get(memberPath).data.active == true;
      }

      function getMemberRole() {
        return firestore.get(
          /databases/(default)/documents/labs/$(labId)/members/$(request.auth.uid)
        ).data.role;
      }

      function isAdminOrOwner() {
        let role = getMemberRole();
        return role == 'admin' || role == 'owner';
      }

      allow read:           if isSuperAdmin() || isActiveMember();
      allow create, update: if isSuperAdmin() || (isActiveMember() && isAdminOrOwner());
      allow delete:         if false;
    }

    // ── CIQ-Imuno strip images: any active member uploads, admin/owner deletes
    // Mirrors the hematology /runs override so operators can attach strip
    // photos without admin role. See storagePath.imunoStripImage().

    match /labs/{labId}/ciq-imuno/{lotId}/strips/{runId} {

      function isAuth() {
        return request.auth != null;
      }

      function isSuperAdmin() {
        return isAuth() &&
          firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true;
      }

      function isActiveMember() {
        let memberPath = /databases/(default)/documents/labs/$(labId)/members/$(request.auth.uid);
        return isAuth() &&
          firestore.exists(memberPath) &&
          firestore.get(memberPath).data.active == true;
      }

      function getMemberRole() {
        return firestore.get(
          /databases/(default)/documents/labs/$(labId)/members/$(request.auth.uid)
        ).data.role;
      }

      function isAdminOrOwner() {
        let role = getMemberRole();
        return role == 'admin' || role == 'owner';
      }

      allow read:          if isSuperAdmin() || isActiveMember();
      allow create, update: if isSuperAdmin() || isActiveMember();
      allow delete:        if isSuperAdmin() || (isActiveMember() && isAdminOrOwner());
    }

    // ── Educação Continuada: materiais didáticos (Fase 6 — 2026-04-24) ────────
    // Path: educacaoContinuada/{labId}/materiais/{templateId}/{filename}
    // Escritas exigem:
    //   - auth + claim modules['educacao-continuada']
    //   - member ativo do lab
    //   - tamanho ≤ 50MB (cap server-side duplica o check client-side)
    //   - MIME em {application/pdf, video/*, image/jpeg, image/png}

    match /educacaoContinuada/{labId}/materiais/{templateId}/{filename} {

      function isAuth() {
        return request.auth != null;
      }

      function hasEcModuleClaim() {
        return isAuth() &&
          request.auth.token.modules != null &&
          request.auth.token.modules['educacao-continuada'] == true;
      }

      function isActiveMember() {
        let memberPath = /databases/(default)/documents/labs/$(labId)/members/$(request.auth.uid);
        return isAuth() &&
          firestore.exists(memberPath) &&
          firestore.get(memberPath).data.active == true;
      }

      function isSuperAdmin() {
        return isAuth() &&
          firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true;
      }

      function isAllowedContentType() {
        return request.resource.contentType.matches('application/pdf')
            || request.resource.contentType.matches('video/.*')
            || request.resource.contentType.matches('image/jpeg')
            || request.resource.contentType.matches('image/png');
      }

      function isAllowedSize() {
        return request.resource.size <= 50 * 1024 * 1024;
      }

      allow read: if isSuperAdmin() || (hasEcModuleClaim() && isActiveMember());

      allow create, update: if (isSuperAdmin() || (hasEcModuleClaim() && isActiveMember()))
                            && isAllowedContentType()
                            && isAllowedSize();

      allow delete: if isSuperAdmin() || (hasEcModuleClaim() && isActiveMember());
    }

    // ── Laudo PDFs (Phase 10-04) ──────────────────────────────────────────────
    // Path: laudos/{labId}/{laudoId}/v{version}.pdf
    // Writes are server-only (generateLaudoPDF callable via Admin SDK signed URL).
    // Reads: active members of the lab (via Firestore membership) OR signed URL.
    // The signed URL flow (returned by the callable) bypasses these rules and
    // is the canonical access path for clients; this rule covers direct
    // SDK-based reads (e.g., LaudoPDFPreview iframe loaded via gs://).
    match /laudos/{labId}/{laudoId}/{filename} {

      function isAuth() {
        return request.auth != null;
      }

      function isSuperAdmin() {
        return isAuth() &&
          firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true;
      }

      function isActiveMember() {
        let memberPath = /databases/(default)/documents/labs/$(labId)/members/$(request.auth.uid);
        return isAuth() &&
          firestore.exists(memberPath) &&
          firestore.get(memberPath).data.active == true;
      }

      allow read:   if isSuperAdmin() || isActiveMember();
      allow write:  if false;  // Server-only via Admin SDK
    }

    // ── Phase 5 — LGPD consent paper trail (signed PDFs) ─────────────────────
    // Operators upload scanned/signed TCLE forms. Active lab members upload only;
    // contentType + size guarded. Reads remain governed by the catch-all above
    // (active members can read all lab assets).
    match /labs/{labId}/consent-paper-trail/{patientId}/{file=**} {
      allow write: if request.auth != null
                   && firestore.exists(/databases/(default)/documents/labs/$(labId)/members/$(request.auth.uid))
                   && firestore.get(/databases/(default)/documents/labs/$(labId)/members/$(request.auth.uid)).data.active == true
                   && request.resource.contentType == 'application/pdf'
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // ── Consent backfill CSV exports (signed-URL only) ───────────────────────
    // Outside /labs/ to keep the catch-all from granting reads. Cloud Function
    // service account writes via Admin SDK; clients access via 24h v4-signed URL.
    match /exports/{labId}/consent-backfill/{file=**} {
      allow read, write: if false;
    }

    // ── IA Strip Images: imuno-ias bucket for hematology quantitative analysis ──
    // Path: labs/{labId}/imuno-ias/{stripId}/*
    // Authenticated users upload strip images (PNG/JPEG ≤5MB) with metadata audit.
    // Read/delete restricted to RT or admin per Phase 5 requirements.
    // Metadata must include: labId, uploadedBy, timestamp (client-enforced,
    // server-validated via custom metadata in request.resource.metadata).

    match /labs/{labId}/imuno-ias/{stripId}/{filename} {

      function isAuth() {
        return request.auth != null;
      }

      function isSuperAdmin() {
        return isAuth() &&
          firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true;
      }

      function isActiveMember() {
        let memberPath = /databases/(default)/documents/labs/$(labId)/members/$(request.auth.uid);
        return isAuth() &&
          firestore.exists(memberPath) &&
          firestore.get(memberPath).data.active == true;
      }

      function getMemberRole() {
        return firestore.get(
          /databases/(default)/documents/labs/$(labId)/members/$(request.auth.uid)
        ).data.role;
      }

      function isAdminOrOwner() {
        let role = getMemberRole();
        return role == 'admin' || role == 'owner';
      }

      function isRtRole() {
        let role = getMemberRole();
        return role == 'RT';
      }

      function isImageType() {
        return request.resource.contentType == 'image/png'
            || request.resource.contentType == 'image/jpeg';
      }

      function isSizeValid() {
        return request.resource.size <= 5 * 1024 * 1024;  // 5MB max
      }

      function hasMetadata() {
        return request.resource.metadata != null
            && request.resource.metadata.labId == labId
            && request.resource.metadata.uploadedBy == request.auth.uid
            && request.resource.metadata.timestamp != null;
      }

      // Read: RT or admin/owner only
      allow read: if isSuperAdmin() || (isActiveMember() && (isAdminOrOwner() || isRtRole()));

      // Write: authenticated active member, image type/size enforced, metadata required
      allow create, update: if isActiveMember()
                            && isImageType()
                            && isSizeValid()
                            && hasMetadata();

      // Delete: admin/owner or superAdmin only
      allow delete: if isSuperAdmin() || (isActiveMember() && isAdminOrOwner());
    }

    // ── Auditoria Geral: evidencias fotograficas por indicador ────────────────
    // Path: auditoria-geral/{labId}/{auditoriaId}/{indicadorId}/{filename}
    // Active lab members can upload images (JPEG/PNG/WebP ≤5MB).
    // Delete: admin/owner only. Fotos são evidência regulatória.
    match /auditoria-geral/{labId}/{auditoriaId}/{indicadorId}/{filename} {

      function isAuth() {
        return request.auth != null;
      }

      function isSuperAdmin() {
        return isAuth() &&
          firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true;
      }

      function isActiveMember() {
        let memberPath = /databases/(default)/documents/labs/$(labId)/members/$(request.auth.uid);
        return isAuth() &&
          firestore.exists(memberPath) &&
          firestore.get(memberPath).data.active == true;
      }

      function getMemberRole() {
        return firestore.get(
          /databases/(default)/documents/labs/$(labId)/members/$(request.auth.uid)
        ).data.role;
      }

      function isAdminOrOwner() {
        let role = getMemberRole();
        return role == 'admin' || role == 'owner';
      }

      function isImageType() {
        return request.resource.contentType == 'image/jpeg'
            || request.resource.contentType == 'image/png'
            || request.resource.contentType == 'image/webp';
      }

      function isSizeValid() {
        return request.resource.size <= 5 * 1024 * 1024;
      }

      allow read: if isSuperAdmin() || isActiveMember();
      allow create, update: if (isSuperAdmin() || isActiveMember())
                            && isImageType()
                            && isSizeValid();
      allow delete: if isSuperAdmin() || (isActiveMember() && isAdminOrOwner());
    }
  }
}
