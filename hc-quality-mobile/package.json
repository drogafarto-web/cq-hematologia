{
  "name": "hc-quality-mobile",
  "version": "1.0.0",
  "description": "HC Quality — Multi-tenant mobile app for clinical quality control",
  "main": "App.tsx",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "test:unit": "jest",
    "lint": "eslint .",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "xcodebuild -workspace ios/hcQualityMobile.xcworkspace -scheme hcQualityMobile -configuration Release"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-native": "^0.75.3",
    "firebase": "^10.14.1",
    "zustand": "^5.0.12",
    "@react-native-async-storage/async-storage": "^1.23.1"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.4.4",
    "@testing-library/jest-native": "^5.4.3",
    "@types/jest": "^29.5.11",
    "@types/react": "^18.2.45",
    "@types/react-native": "^0.73.0",
    "jest": "^29.7.0",
    "jest-preset-expo": "^29.2.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.9.3"
  },
  "keywords": ["react-native", "firebase", "zustand", "mobile"],
  "author": "HC Quality CTO",
  "license": "MIT"
}
