{
  "rule": [
    {
      "action": { "type": "Delete" },
      "condition": { "age": 1825 }
    },
    {
      "action": { "storageClass": "COLDLINE", "type": "SetStorageClass" },
      "condition": { "age": 30, "matchesStorageClass": ["NEARLINE"] }
    },
    {
      "action": { "storageClass": "ARCHIVE", "type": "SetStorageClass" },
      "condition": { "age": 365, "matchesStorageClass": ["COLDLINE"] }
    }
  ]
}
