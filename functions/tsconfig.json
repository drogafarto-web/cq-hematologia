{
  "compilerOptions": {
    "module": "commonjs",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2020",
    "lib": ["es2022", "DOM"],
    "skipLibCheck": true,
    "types": ["node"]
  },
  "compileOnSave": true,
  "include": ["src"],
  "exclude": [
    "node_modules",
    "../node_modules",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/__tests__/**",
    "src/modules/criticos/**",
    "src/modules/notivisa/**",
    "src/modules/ia-strip/**",
    "src/modules/portals/**"
  ]
}
